def run_binary_ethnic_no_leakage():
    merged = merge_main_and_ethnic().copy()

    train_df, test_df = train_test_split(
        merged,
        test_size=0.25,
        stratify=np.where(merged["Political Affiliation"] == "Liberal", 1, -1),
        random_state=42
    )

    ethnic_cols = [c for c in merged.columns if c.startswith("rate_")]
    screened = screen_ethnic_variables_on_training(train_df, ethnic_cols)

    print("\n===== TOP ETHNIC-GROUP VARIABLES (TRAINING ONLY) =====")
    print(screened.head(15).to_string(index=False))

    top5 = screened.head(5)["variable"].tolist()
    print("\nSelected top ethnic-group variables from training only:")
    print(top5)

    plot_top_ethnic_variables(screened, top_n=10)
    plot_liberal_vs_nonliberal_ethnic_profile(screened, top_n=8)

    # baseline
    X_train_base, y_train_base = build_binary_baseline_X(train_df)
    X_test_base, y_test_base = build_binary_baseline_X(test_df)

    common_base_cols = sorted(set(X_train_base.columns).intersection(X_test_base.columns))
    X_train_base = X_train_base[common_base_cols]
    X_test_base = X_test_base[common_base_cols]

    # ethnic subset
    X_train_sub, y_train_sub = build_binary_subset_X(train_df, top5)
    X_test_sub, y_test_sub = build_binary_subset_X(test_df, top5)

    common_sub_cols = sorted(set(X_train_sub.columns).intersection(X_test_sub.columns))
    X_train_sub = X_train_sub[common_sub_cols]
    X_test_sub = X_test_sub[common_sub_cols]

    # remove missing rows separately
    base_train_mask = ~X_train_base.isna().any(axis=1)
    base_test_mask = ~X_test_base.isna().any(axis=1)
    X_train_base = X_train_base.loc[base_train_mask]
    X_test_base = X_test_base.loc[base_test_mask]
    y_train_base = y_train_base[base_train_mask.to_numpy()]
    y_test_base = y_test_base[base_test_mask.to_numpy()]

    sub_train_mask = ~X_train_sub.isna().any(axis=1)
    sub_test_mask = ~X_test_sub.isna().any(axis=1)
    X_train_sub = X_train_sub.loc[sub_train_mask]
    X_test_sub = X_test_sub.loc[sub_test_mask]
    y_train_sub = y_train_sub[sub_train_mask.to_numpy()]
    y_test_sub = y_test_sub[sub_test_mask.to_numpy()]

    def run_one(Xtr, Xte, ytr, yte, label):
        Xtr_scaled, Xte_scaled = preprocess_data(Xtr.values, Xte.values, degree=3)
        result = train_svm_bfgs(Xtr_scaled, ytr, lambda_reg=0.01, maxiter=200)

        ytr_pred = predict_bfgs(result.x, Xtr_scaled)
        yte_pred = predict_bfgs(result.x, Xte_scaled)

        train_acc = accuracy_score(ytr, ytr_pred)
        test_acc = accuracy_score(yte, yte_pred)
        cm = confusion_matrix(yte, yte_pred)

        print(f"\n===== {label} =====")
        print("Training Accuracy:", round(train_acc, 4))
        print("Testing Accuracy:", round(test_acc, 4))
        print("\nConfusion Matrix:")
        print(cm)
        print("\nClassification Report:")
        print(classification_report(yte, yte_pred, zero_division=0))

        plot_conf_matrix_pretty(
            cm,
            class_names=["Non-Liberal", "Liberal"],
            title=label + " Confusion Matrix"
        )

        return {
            "Model": label,
            "Train Accuracy": train_acc,
            "Test Accuracy": test_acc,
            "Train Rows": len(ytr),
            "Test Rows": len(yte)
        }

    baseline_results = run_one(
        X_train_base, X_test_base, y_train_base, y_test_base,
        "Binary Baseline BFGS"
    )

    ethnic_results = run_one(
        X_train_sub, X_test_sub, y_train_sub, y_test_sub,
        "Binary BFGS + Top 5 Ethnic-Group Variables"
    )

    comparison = pd.DataFrame([baseline_results, ethnic_results])
    print("\n===== BINARY ETHNIC-GROUP NO-LEAKAGE COMPARISON =====")
    print(comparison.to_string(index=False))

    plot_metric_comparison(
