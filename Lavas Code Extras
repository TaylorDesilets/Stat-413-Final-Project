def ethnic_distribution_summary(merged, top_vars):
    df = merged.copy()
    df["binary_party"] = np.where(
        df["Political Affiliation"] == "Liberal",
        "Liberal",
        "Non-Liberal"
    )

    rows = []

    for var in top_vars:
        lib = pd.to_numeric(df.loc[df["binary_party"] == "Liberal", var], errors="coerce").dropna()
        non = pd.to_numeric(df.loc[df["binary_party"] == "Non-Liberal", var], errors="coerce").dropna()

        if len(lib) < 5 or len(non) < 5:
            continue

        t_stat, p_val = ttest_ind(lib, non, equal_var=False, nan_policy="omit")
        d = cohens_d(lib, non)

        rows.append({
            "variable": var,
            "liberal_mean": lib.mean(),
            "non_liberal_mean": non.mean(),
            "liberal_median": lib.median(),
            "non_liberal_median": non.median(),
            "liberal_q1": lib.quantile(0.25),
            "liberal_q3": lib.quantile(0.75),
            "non_liberal_q1": non.quantile(0.25),
            "non_liberal_q3": non.quantile(0.75),
            "mean_difference": lib.mean() - non.mean(),
            "p_value": p_val,
            "cohens_d": d
        })

    summary = pd.DataFrame(rows).sort_values("p_value")
    print("\n===== ETHNIC DISTRIBUTION SUMMARY =====")
    print(summary.to_string(index=False))

    summary.to_csv("ethnic_distribution_summary.csv", index=False)
    return summary


