def screen_ethnic_variables_on_training(train_df, candidate_cols):
    train_df = train_df.copy()
    train_df["is_liberal"] = (train_df["Political Affiliation"] == "Liberal").astype(int)

    rows = []
    for col in candidate_cols:
        x = pd.to_numeric(train_df[col], errors="coerce")
        mask = x.notna()

        if mask.sum() < 20:
            continue

        lib_vals = x[(train_df["is_liberal"] == 1) & mask]
        non_vals = x[(train_df["is_liberal"] == 0) & mask]

        if len(lib_vals) < 5 or len(non_vals) < 5:
            continue

        mean_lib = lib_vals.mean()
        mean_non = non_vals.mean()
        diff = mean_lib - mean_non

        t_stat, p_val = ttest_ind(lib_vals, non_vals, equal_var=False, nan_policy="omit")

        rows.append({
            "variable": col,
            "mean_liberal": mean_lib,
            "mean_non_liberal": mean_non,
            "difference": diff,
            "abs_difference": abs(diff),
            "p_value": p_val
        })

    results = pd.DataFrame(rows).sort_values(["abs_difference", "p_value"], ascending=[False, True])
    return results


