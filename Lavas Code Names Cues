def add_name_cue_features(cand_df):
    df = cand_df.copy()

    split_names = df["candidate_name"].apply(safe_split_name)
    df["first_name"] = split_names.apply(lambda x: x[0])
    df["last_name"] = split_names.apply(lambda x: x[1])

    df["cue_first_name_len"] = df["first_name"].str.len()
    df["cue_last_name_len"] = df["last_name"].str.len()
    df["cue_full_name_len"] = df["candidate_name"].str.len()

    df["cue_first_name_word_count"] = df["first_name"].str.split().apply(len)
    df["cue_last_name_word_count"] = df["last_name"].str.split().apply(len)
    df["cue_full_name_word_count"] = df["candidate_name"].str.split().apply(len)

    df["cue_has_hyphen"] = df["candidate_name"].str.contains("-", regex=False).astype(int)
    df["cue_has_apostrophe"] = df["candidate_name"].str.contains("'", regex=False).astype(int)
    df["cue_has_period"] = df["candidate_name"].str.contains(".", regex=False).astype(int)
    df["cue_has_accent"] = df["candidate_name"].apply(has_accented_characters)
    df["cue_uppercase_ratio"] = df["candidate_name"].apply(uppercase_ratio)
    df["cue_vowel_ratio"] = df["candidate_name"].apply(vowel_ratio)

    def same_initial(row):
        f = row["first_name"]
        l = row["last_name"]
        if pd.isna(f) or pd.isna(l) or len(f) == 0 or len(l) == 0:
            return 0
        return int(f[0].lower() == l[0].lower())

    df["cue_same_initial"] = df.apply(same_initial, axis=1)

    df["cue_first_name_is_initial_like"] = df["first_name"].str.fullmatch(
        r"[A-Za-z]\.?", na=False
    ).astype(int)

    return df


def cue_cols(df):
    return [c for c in df.columns if c.startswith("cue_")]


