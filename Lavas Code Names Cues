# 5. BUILD CANDIDATE-LEVEL DATASET
# ============================================================

def candidate_columns(df):
    return [
        c for c in df.columns
        if c not in META_COLS and c != "source_file"
    ]


def aggregate_candidate_level_from_poll_df(df):
    cand_cols = candidate_columns(df)

    riding_num = df[ED_NUM_COL].iloc[0]
    riding_name = df[ED_NAME_COL].iloc[0]
    total_votes_riding = pd.to_numeric(df[TOTAL_VOTES_COL], errors="coerce").sum()
    electors_riding = pd.to_numeric(df[ELECTORS_COL], errors="coerce").sum()
    rejected_riding = pd.to_numeric(df[REJECTED_COL], errors="coerce").sum()

    rows = []
    for cand in cand_cols:
        votes = pd.to_numeric(df[cand], errors="coerce").fillna(0).sum()

        rows.append({
            "district_number": riding_num,
            "riding_name": riding_name,
            "candidate_name": cand,
            "candidate_votes": votes,
            "riding_total_votes": total_votes_riding,
            "riding_total_electors": electors_riding,
            "riding_rejected_ballots": rejected_riding
        })

    out = pd.DataFrame(rows)

    out["vote_share"] = out["candidate_votes"] / out["riding_total_votes"]
    out["turnout_pct"] = out["riding_total_votes"] / out["riding_total_electors"]
    out["rejected_ballot_pct"] = out["riding_rejected_ballots"] / (
        out["riding_total_votes"] + out["riding_rejected_ballots"]
    )

    out = out.sort_values(["district_number", "candidate_votes"], ascending=[True, False]).copy()
    out["rank_in_riding"] = out.groupby("district_number")["candidate_votes"].rank(
        method="dense", ascending=False
    )
    out["is_winner"] = (out["rank_in_riding"] == 1).astype(int)

    if out["candidate_votes"].sum() > 0:
        top_votes = out["candidate_votes"].max()
        second_votes = out["candidate_votes"].nlargest(2).iloc[-1] if len(out) > 1 else 0
        margin = (top_votes - second_votes) / total_votes_riding if total_votes_riding > 0 else np.nan
    else:
        margin = np.nan

    out["riding_margin_of_victory"] = margin

    return out


def build_all_candidate_dataset(zip_path):
    poll_dfs = read_all_poll_csvs_from_zip(zip_path)
    candidate_level_list = [aggregate_candidate_level_from_poll_df(df) for df in poll_dfs]
    cand_df = pd.concat(candidate_level_list, ignore_index=True)

    print("\n===== CANDIDATE-LEVEL DATASET =====")
    print("Rows:", cand_df.shape[0])
    print("Columns:", cand_df.shape[1])
    print(cand_df.head())

    cand_df.to_csv("candidate_level_from_poll_zip.csv", index=False)
    return cand_df


