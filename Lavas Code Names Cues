def screen_cues_on_training(train_df):
    rows = []
    for col in cue_cols(train_df):
        x = pd.to_numeric(train_df[col], errors="coerce")
        y = pd.to_numeric(train_df["vote_share"], errors="coerce")
        mask = x.notna() & y.notna()

        if mask.sum() < 20:
            continue

        rho, p = spearmanr(x[mask], y[mask])

        rows.append({
            "variable": col,
            "spearman_rho": rho,
            "p_value": p,
            "abs_rho": abs(rho) if pd.notna(rho) else np.nan
        })

    screened = pd.DataFrame(rows).sort_values("abs_rho", ascending=False)
    print("\n===== TOP SCREENED NAME CUES (TRAINING ONLY) =====")
    print(screened.to_string(index=False))
    screened.to_csv("candidate_cue_training_screening.csv", index=False)
    return screened


def build_baseline_X(df):
    cols = [
        "riding_total_votes",
        "riding_total_electors",
        "turnout_pct",
        "rejected_ballot_pct",
        "riding_margin_of_victory"
    ]
    return df[cols].copy()


def build_with_cues_X(df, chosen_cues):
    cols = [
        "riding_total_votes",
        "riding_total_electors",
        "turnout_pct",
        "rejected_ballot_pct",
        "riding_margin_of_victory"
    ] + chosen_cues
    return df[cols].copy()


def run_vote_share_regression(df):
    train_df, test_df = train_test_split(df, test_size=0.25, random_state=42)

    screened = screen_cues_on_training(train_df)
    top5 = screened.head(5)["variable"].tolist()
    print("\nSelected top 5 candidate cues:")
    print(top5)

    X_train_base = build_baseline_X(train_df)
    X_test_base = build_baseline_X(test_df)

    X_train_cue = build_with_cues_X(train_df, top5)
    X_test_cue = build_with_cues_X(test_df, top5)

    y_train = train_df["vote_share"].values
    y_test = test_df["vote_share"].values

    def fit_eval(Xtr, Xte, ytr, yte, label):
        pipe = Pipeline([
            ("scaler", StandardScaler()),
            ("lr", LinearRegression())
        ])
        pipe.fit(Xtr, ytr)
        pred_tr = pipe.predict(Xtr)
        pred_te = pipe.predict(Xte)

        rmse_tr = np.sqrt(mean_squared_error(ytr, pred_tr))
        rmse_te = np.sqrt(mean_squared_error(yte, pred_te))
        r2_tr = r2_score(ytr, pred_tr)
        r2_te = r2_score(yte, pred_te)

        print(f"\n===== {label} =====")
        print("Train RMSE:", round(rmse_tr, 4))
        print("Test RMSE:", round(rmse_te, 4))
        print("Train R^2:", round(r2_tr, 4))
        print("Test R^2:", round(r2_te, 4))

        return {
            "Model": label,
            "Train RMSE": rmse_tr,
            "Test RMSE": rmse_te,
            "Train R2": r2_tr,
            "Test R2": r2_te
        }

    base_res = fit_eval(X_train_base, X_test_base, y_train, y_test, "Vote Share Baseline")
    cue_res = fit_eval(X_train_cue, X_test_cue, y_train, y_test, "Vote Share + Top 5 Candidate Cues")

    comp = pd.DataFrame([base_res, cue_res])
    print("\n===== VOTE SHARE REGRESSION COMPARISON =====")
    print(comp.to_string(index=False))
    comp.to_csv("candidate_cue_vote_share_model_comparison.csv", index=False)

    plot_two_bar(
        values=comp["Test R2"].tolist(),
        labels=comp["Model"].tolist(),
        title="Vote Share Regression: Test R^2 Comparison",
        ylabel="Test R^2"
    )

    return screened, comp, top5


def run_winner_classification(df, top5):
    train_df, test_df = train_test_split(
        df,
        test_size=0.25,
        stratify=df["is_winner"],
        random_state=42
    )

    X_train_base = build_baseline_X(train_df)
    X_test_base = build_baseline_X(test_df)

    X_train_cue = build_with_cues_X(train_df, top5)
    X_test_cue = build_with_cues_X(test_df, top5)

    y_train = train_df["is_winner"].values
    y_test = test_df["is_winner"].values

    def fit_eval(Xtr, Xte, ytr, yte, label):
        pipe = Pipeline([
            ("scaler", StandardScaler()),
            ("clf", LogisticRegression(max_iter=2000))
        ])
        pipe.fit(Xtr, ytr)
        pred_tr = pipe.predict(Xtr)
        pred_te = pipe.predict(Xte)

        train_acc = accuracy_score(ytr, pred_tr)
        test_acc = accuracy_score(yte, pred_te)
        cm = confusion_matrix(yte, pred_te)

        print(f"\n===== {label} =====")
        print("Train Accuracy:", round(train_acc, 4))
        print("Test Accuracy:", round(test_acc, 4))
        print("\nConfusion Matrix:")
        print(cm)
        print("\nClassification Report:")
        print(classification_report(yte, pred_te, zero_division=0))

        plot_conf_matrix_pretty(cm, ["Loser", "Winner"], label + " Confusion Matrix")

        return {
            "Model": label,
            "Train Accuracy": train_acc,
            "Test Accuracy": test_acc
        }

    base_res = fit_eval(X_train_base, X_test_base, y_train, y_test, "Winner Baseline")
    cue_res = fit_eval(X_train_cue, X_test_cue, y_train, y_test, "Winner + Top 5 Candidate Cues")

    comp = pd.DataFrame([base_res, cue_res])
    print("\n===== WINNER CLASSIFICATION COMPARISON =====")
    print(comp.to_string(index=False))
    comp.to_csv("candidate_cue_winner_classification_comparison.csv", index=False)

    plot_two_bar(
        values=comp["Test Accuracy"].tolist(),
        labels=comp["Model"].tolist(),
        title="Winner Classification: Test Accuracy Comparison",
        ylabel="Test Accuracy"
    )

    return comp


def run_candidate_models(df, label="ALL CANDIDATES"):
    print(f"\n================ MODELING: {label} ================\n")

    if df["is_winner"].nunique() < 2:
        print("Not enough class variation for winner classification.")
        return None, None, None

    if df["district_number"].nunique() < 10:
        print("Too few ridings for stable modeling.")
        return None, None, None

    screened, reg_comp, top5 = run_vote_share_regression(df)
    class_comp = run_winner_classification(df, top5)

    print(f"\nTop 5 cues for {label}: {top5}")

    return screened, reg_comp, class_comp


