def subset_close_races(df, threshold=0.05):
    out = df[df["riding_margin_of_victory"] < threshold].copy()
    print(f"\nRows in close-race subset (margin < {threshold:.0%}): {out.shape[0]}")
    print(f"Unique ridings in close-race subset: {out['district_number'].nunique()}")
    return out


def run_close_race_candidate_cue_analysis(df):
    print("\n================ CLOSE-RACE ANALYSIS =================\n")

    close_5 = subset_close_races(df, threshold=0.05)
    close_10 = subset_close_races(df, threshold=0.10)
    non_close = df[df["riding_margin_of_victory"] >= 0.10].copy()

    if close_5.shape[0] > 0:
        run_descriptive_candidate_cue_analysis(close_5, label="CLOSE RACES (<5%)")

    if close_10.shape[0] > 0:
        run_descriptive_candidate_cue_analysis(close_10, label="CLOSE RACES (<10%)")

    if non_close.shape[0] > 0:
        run_descriptive_candidate_cue_analysis(non_close, label="NON-CLOSE RACES (>=10%)")

    results = {}

    if close_5["district_number"].nunique() >= 10:
        results["close_5"] = run_candidate_models(close_5, label="CLOSE RACES (<5%)")

    if close_10["district_number"].nunique() >= 10:
        results["close_10"] = run_candidate_models(close_10, label="CLOSE RACES (<10%)")

    if non_close["district_number"].nunique() >= 10:
        results["non_close"] = run_candidate_models(non_close, label="NON-CLOSE RACES (>=10%)")

    return results


