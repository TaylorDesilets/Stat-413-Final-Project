def winner_vs_loser_summary(df):
    rows = []
    for col in cue_cols(df):
        winners = pd.to_numeric(df.loc[df["is_winner"] == 1, col], errors="coerce").dropna()
        losers = pd.to_numeric(df.loc[df["is_winner"] == 0, col], errors="coerce").dropna()

        if len(winners) < 5 or len(losers) < 5:
            continue

        t_stat, p_val = ttest_ind(winners, losers, equal_var=False, nan_policy="omit")
        d = cohens_d(winners, losers)

        rows.append({
            "variable": col,
            "winner_mean": winners.mean(),
            "loser_mean": losers.mean(),
            "difference": winners.mean() - losers.mean(),
            "p_value": p_val,
            "cohens_d": d
        })

    summary = pd.DataFrame(rows).sort_values("p_value")
    print("\n===== WINNER VS LOSER SUMMARY =====")
    print(summary.to_string(index=False))
    summary.to_csv("candidate_cue_winner_vs_loser_summary.csv", index=False)
    return summary


def vote_share_correlation_summary(df):
    rows = []
    for col in cue_cols(df):
        x = pd.to_numeric(df[col], errors="coerce")
        y = pd.to_numeric(df["vote_share"], errors="coerce")
        mask = x.notna() & y.notna()

        if mask.sum() < 20:
            continue

        rho, p = spearmanr(x[mask], y[mask])

        rows.append({
            "variable": col,
            "spearman_rho": rho,
            "p_value": p,
            "abs_rho": abs(rho) if pd.notna(rho) else np.nan
        })

    summary = pd.DataFrame(rows).sort_values("abs_rho", ascending=False)
    print("\n===== VOTE SHARE CORRELATION SUMMARY =====")
    print(summary.to_string(index=False))
    summary.to_csv("candidate_cue_vote_share_correlations.csv", index=False)
    return summary


def within_riding_rank_summary(df):
    rows = []
    for col in cue_cols(df):
        x = pd.to_numeric(df[col], errors="coerce")
        y = pd.to_numeric(df["rank_in_riding"], errors="coerce")
        mask = x.notna() & y.notna()

        if mask.sum() < 20:
            continue

        rho, p = spearmanr(x[mask], y[mask])

        rows.append({
            "variable": col,
            "spearman_rho_with_rank": rho,
            "p_value": p,
            "abs_rho": abs(rho) if pd.notna(rho) else np.nan
        })

    summary = pd.DataFrame(rows).sort_values("abs_rho", ascending=False)
    print("\n===== WITHIN-RIDING RANK SUMMARY =====")
    print(summary.to_string(index=False))
    summary.to_csv("candidate_cue_rank_correlations.csv", index=False)
    return summary


def make_descriptive_plots(df, winner_summary, corr_summary):
    if not winner_summary.empty:
        top = winner_summary.head(8)
        plot_horizontal_bar(
            labels=top["variable"].tolist(),
            values=top["difference"].abs().tolist(),
            title="Winner vs Loser: Top Candidate-Cue Differences",
            xlabel="Absolute mean difference"
        )

    if not corr_summary.empty:
        top = corr_summary.head(8)
        plot_horizontal_bar(
            labels=top["variable"].tolist(),
            values=top["abs_rho"].fillna(0).tolist(),
            title="Top Candidate-Cue Correlations with Vote Share",
            xlabel="Absolute Spearman correlation"
        )

    vars_for_boxplots = []
    if not winner_summary.empty:
        vars_for_boxplots = winner_summary.head(4)["variable"].tolist()

    if vars_for_boxplots:
        tmp = df.copy()
        tmp["winner_label"] = np.where(tmp["is_winner"] == 1, "Winner", "Loser")
        plot_boxplots(tmp, vars_for_boxplots, "winner_label")


def run_descriptive_candidate_cue_analysis(df, label="ALL CANDIDATES"):
    print(f"\n================ DESCRIPTIVE ANALYSIS: {label} ================\n")

    winner_summary = winner_vs_loser_summary(df)
    corr_summary = vote_share_correlation_summary(df)
    rank_summary = within_riding_rank_summary(df)

    make_descriptive_plots(df, winner_summary, corr_summary)

    return winner_summary, corr_summary, rank_summary


