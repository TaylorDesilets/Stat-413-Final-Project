def read_all_poll_csvs_from_zip(zip_path):
    if not os.path.exists(zip_path):
        raise FileNotFoundError(f"Could not find zip file: {zip_path}")

    all_dfs = []
    with zipfile.ZipFile(zip_path, "r") as zf:
        csv_names = [name for name in zf.namelist() if name.lower().endswith(".csv")]
        print(f"Found {len(csv_names)} poll CSV files in ZIP")

        for i, name in enumerate(csv_names, start=1):
            with zf.open(name) as f:
                df = pd.read_csv(f)
                df["source_file"] = os.path.basename(name)
                all_dfs.append(df)

            if i % 50 == 0 or i == len(csv_names):
                print(f"Processed {i} / {len(csv_names)} files")

    return all_dfs


