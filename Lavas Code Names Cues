def normalize_text(x):
    if pd.isna(x):
        return np.nan
    x = str(x)
    x = unicodedata.normalize("NFKD", x)
    x = "".join(ch for ch in x if not unicodedata.combining(ch))
    x = x.lower().strip()
    x = x.replace("—", "-").replace("–", "-").replace("’", "'").replace("`", "'")
    x = x.replace("/", " ")
    x = x.replace("-", " ")
    x = x.replace("'", " ")
    x = re.sub(r"[^a-z0-9\s]", " ", x)
    x = re.sub(r"\s+", " ", x).strip()
    return x


def has_accented_characters(text):
    if pd.isna(text):
        return 0
    text = str(text)
    normalized = unicodedata.normalize("NFD", text)
    return int(any(unicodedata.combining(ch) for ch in normalized))


def uppercase_ratio(s):
    s = "" if pd.isna(s) else str(s)
    letters = [ch for ch in s if ch.isalpha()]
    if len(letters) == 0:
        return 0.0
    return sum(ch.isupper() for ch in letters) / len(letters)


def vowel_ratio(s):
    s = "" if pd.isna(s) else str(s).lower()
    letters = [ch for ch in s if ch.isalpha()]
    if len(letters) == 0:
        return 0.0
    vowels = sum(ch in "aeiou" for ch in letters)
    return vowels / len(letters)


def safe_split_name(full_name):
    full_name = "" if pd.isna(full_name) else str(full_name).strip()
    parts = full_name.split()
    if len(parts) == 0:
        return "", ""
    if len(parts) == 1:
        return parts[0], ""
    return parts[0], " ".join(parts[1:])


def cohens_d(x, y):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    x = x[~np.isnan(x)]
    y = y[~np.isnan(y)]

    if len(x) < 2 or len(y) < 2:
        return np.nan

    nx, ny = len(x), len(y)
    sx, sy = np.var(x, ddof=1), np.var(y, ddof=1)

    pooled_std = np.sqrt(((nx - 1) * sx + (ny - 1) * sy) / (nx + ny - 2))
    if pooled_std == 0:
        return np.nan

    return (np.mean(x) - np.mean(y)) / pooled_std


